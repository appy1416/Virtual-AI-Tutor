# ------------------------------------------------------------------------------
# EduTwin AI - Root Gitignore Config
# Covers Python/FastAPI, Node.js/React, docker configurations, logs, and IDEs
# ------------------------------------------------------------------------------

# --- System Files ---
.DS_Store
Thumbs.db
*.db
*.log

# --- IDEs and Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.project
.pydevproject

# --- Python / Backend specific ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
.cfg
.venv/
venv/
ENV/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
instance/
.webassets-cache
celerybeat-schedule
pip-log.txt
pip-delete-this-directory.txt

# --- Node / Frontend specific ---
node_modules/
/frontend/dist
/frontend/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Database & Storage Local Cache ---
pgdata/
redisdata/
local_db/

# --- Environment & Configuration ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --- Antigravity IDE and Gemini artifacts (keep user scratch clean) ---
.gemini/
.agents/
!task.md
!implementation_plan.md
!walkthrough.md
