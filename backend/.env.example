# --- Application Environment ---
ENV=development
DEBUG=True
SECRET_KEY=generate_a_secure_random_hex_string

# --- Database ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?appName=AppName

# --- AI Integrations ---
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Authentication Settings ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# --- CORS Permissions ---
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://virtual-ai-tutor.vercel.app"]
