# ------------------------------------------------------------------------------
# EduTwin AI - Frontend Environment Configuration Template (.env.example)
# Rename this file to .env and fill in the actual values. Do not commit .env!
# ------------------------------------------------------------------------------

# --- Application Configuration ---
VITE_APP_NAME="EduTwin AI"
VITE_APP_ENV=development                       # Options: development, production, test

# --- API Endpoints ---
# Base API URL pointing to the FastAPI backend service
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket URL for real-time chat streaming, notifications, or audio streams
VITE_WS_URL=ws://localhost:8000/api/v1

# --- Third-Party Auth Configurations (OAuth2 / Social Login) ---
# Used if Google OAuth flow is enabled directly on frontend
VITE_GOOGLE_CLIENT_ID=placeholder-google-oauth-client-id.apps.googleusercontent.com

# --- Monitoring & Telemetry (Optional) ---
# Sentry DSN for error reporting
VITE_SENTRY_DSN=placeholder-sentry-dsn

# --- Feature Flags ---
VITE_ENABLE_VOICE_MODE=true
VITE_ENABLE_REALTIME_ANALYTICS=true
